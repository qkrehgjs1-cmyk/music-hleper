{
  "version": 2,
  "functions": {
    "api/recommend.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/recommend",
      "dest": "/api/recommend.js",
      "methods": ["POST"]
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai_api_key",
    "YOUTUBE_API_KEY": "@youtube_api_key"
  }
}
